---
import { getLanguageFromUrl, useTranslation } from '@i18n/utils';
import { stackCategories, learning } from '@data/stack';

const lang = getLanguageFromUrl(Astro.url);
const t = useTranslation(lang);
const byKey = Object.fromEntries(stackCategories.map((c) => [c.key, c]));
---

<section
  id="stack"
  class="px-6 sm:px-8 max-w-4xl mx-auto py-16 sm:py-24 border-t border-line"
>
  <h2 class="font-serif text-2xl sm:text-3xl mb-10 sm:mb-14">
    {t('stack.label')}
  </h2>

  <div class="flex flex-col sm:flex-row gap-4">
    <div class="flex flex-col gap-4 sm:w-1/2">
      <div class="border border-line p-6 flex-2">
        <h3
          class="font-sans text-xs uppercase tracking-widest text-accent2 mb-4"
        >
          {t('stack.frontend')}
        </h3>
        <ul class="space-y-3">
          {
            byKey.frontend.items.map((item) => (
              <li class="flex items-center gap-2.5 font-serif text-base sm:text-lg text-ink">
                {item.icon && (
                  <img
                    src={`https://cdn.simpleicons.org/${item.icon}`}
                    alt=""
                    class="w-4 h-4 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                  />
                )}
                {item.name}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="border border-line p-6 flex-1">
        <h3
          class="font-sans text-xs uppercase tracking-widest text-accent2 mb-4"
        >
          {t('stack.database')}
        </h3>
        <ul class="space-y-3">
          {
            byKey.database.items.map((item) => (
              <li class="flex items-center gap-2.5 font-serif text-base sm:text-lg text-ink">
                {item.icon && (
                  <img
                    src={`https://cdn.simpleicons.org/${item.icon}`}
                    alt=""
                    class="w-4 h-4 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                  />
                )}
                {item.name}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Columna derecha: BI + Backend (iguales) -->
    <div class="flex flex-col gap-4 sm:w-1/2">
      <div class="border border-line p-6 flex-1">
        <h3
          class="font-sans text-xs uppercase tracking-widest text-accent2 mb-4"
        >
          {t('stack.bi')}
        </h3>
        <ul class="space-y-3">
          {
            byKey.bi.items.map((item) => (
              <li class="flex items-center gap-2.5 font-serif text-base sm:text-lg text-ink">
                {item.icon && (
                  <img
                    src={`https://cdn.simpleicons.org/${item.icon}`}
                    alt=""
                    class="w-4 h-4 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                  />
                )}
                {item.name}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="border border-line p-6 flex-1">
        <h3
          class="font-sans text-xs uppercase tracking-widest text-accent2 mb-4"
        >
          {t('stack.backend')}
        </h3>
        <ul class="space-y-3">
          {
            byKey.backend.items.map((item) => (
              <li class="flex items-center gap-2.5 font-serif text-base sm:text-lg text-ink">
                {item.icon && (
                  <img
                    src={`https://cdn.simpleicons.org/${item.icon}`}
                    alt=""
                    class="w-4 h-4 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                  />
                )}
                {item.name}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="mt-12">
    <h3 class="font-sans text-xs uppercase tracking-widest text-ink/40 mb-3">
      {t('stack.learning')}
    </h3>
    <p class="font-sans text-sm text-ink/60">
      {
        learning.map((item, i) => (
          <>
            {item}
            {i < learning.length - 1 && (
              <span class="text-accent2 mx-2">—</span>
            )}
          </>
        ))
      }
    </p>
  </div>
</section>
